PORT=4000
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Supabase Postgres — copy strings from Dashboard → Connect → ORM / Prisma.
# URL-encode the DB password (@ %40, + %2B, # %23, etc.) or the parser breaks at @.
# Transaction pooler (app): postgres.<project-ref> @ ...pooler...:6543?pgbouncer=true
# DIRECT_URL for Prisma migrate/db push — pick one:
#   Direct (IPv6 by default): postgres:PASSWORD @ db.<ref>.supabase.co:5432
#   Session pooler (IPv4): postgres.<ref>:PASSWORD @ ...pooler...:5432
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:ENCODED_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:ENCODED_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

# Local SQLite instead: set provider back to sqlite in schema.prisma, then use:
# DATABASE_URL="file:./dev.db"
# (and remove directUrl from schema)

JWT_SECRET=change-this-to-a-long-random-string-in-production

# Stripe (card donations). Never commit real keys. Rotate keys if exposed.
STRIPE_SECRET_KEY=
# From Stripe CLI (`stripe listen --forward-to localhost:4000/api/webhooks/stripe`) or Dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=

ADMIN_EMAIL=admin@fundogs.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Site Admin
