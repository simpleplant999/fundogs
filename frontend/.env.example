NEXT_PUBLIC_API_URL=http://localhost:4000/api
# You may use http://localhost:4000 — /api is added automatically for this app.
# Required for /contact form (POST /api/contact).

# Must be the Publishable key from Dashboard → Developers → API keys (pk_test_…).
# Do NOT use: Secret key (sk_…), PaymentIntent id (pi_… only), or client_key (pi_…_client_…).
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=

# Stripe publishable key (pk_...) — required for in-page card form (Payment Element).
# Hosted Checkout still works with backend STRIPE_SECRET_KEY only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
